# ── Nexus Trading System — Environment Variables ─────────────────────────────
# Copy to .env and fill in your keys.
# Shadow mode works without any API keys (pure simulation).

# Trading mode: shadow | paper | live
TRADING_MODE=shadow

# Alpaca (paper trading — free at alpaca.markets)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic (for LLM reasoning agents — optional in shadow mode)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Logging
LOG_LEVEL=INFO
